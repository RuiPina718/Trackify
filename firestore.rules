rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "ruialexandrepina@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidSubscription(data) {
      return data.keys().hasAll(['userId', 'name', 'amount', 'billingCycle', 'billingDay', 'category', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.amount is number && data.amount >= 0 &&
             data.billingCycle in ['monthly', 'annual', 'weekly', 'yearly'] &&
             data.billingDay is int && data.billingDay >= 1 && data.billingDay <= 31 &&
             (data.get('billingMonth', null) == null || (data.billingMonth is int && data.billingMonth >= 1 && data.billingMonth <= 12)) &&
             (data.get('icon', null) == null || (data.icon is string && data.icon.size() <= 100)) &&
             (data.get('currency', null) == null || (data.currency is string && data.currency.size() <= 3)) &&
             (data.get('startDate', null) == null || (data.startDate is string && data.startDate.size() <= 20)) &&
             data.status in ['active', 'cancelled'];
    }

    // --- Global Admin Override ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- Config Collection ---
    match /config/{configId} {
      allow get: if true; // Everyone needs to see if maintenance is active
      allow write: if isAdmin();
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow list: if isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'currency', 'notifications', 'theme', 'monthlyBudget', 'photoURL', 'bio', 'location'])) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'currency', 'notifications', 'theme', 'monthlyBudget', 'photoURL', 'bio', 'location', 'isAdmin', 'isPremium']))
      );
      allow delete: if isOwner(userId) || isAdmin();
    }

    // --- Subscriptions Collection ---
    match /subscriptions/{subId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && isValidId(subId) && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                      isValidId(subId) && 
                      isValidSubscription(incoming()) &&
                      incoming().createdAt == request.time &&
                      exists(/databases/$(database)/documents/users/$(request.auth.uid));

      allow update: if isSignedIn() && 
                      isValidId(subId) &&
                      existing().userId == request.auth.uid &&
                      incoming().userId == request.auth.uid &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      (
                        // Action: Update Metadata
                        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'amount', 'billingCycle', 'billingDay', 'billingMonth', 'category', 'status', 'updatedAt', 'currency', 'icon', 'startDate']) &&
                        isValidSubscription(incoming())
                      );

      allow delete: if isSignedIn() && isValidId(subId) && existing().userId == request.auth.uid;
    }

    // --- Categories Collection ---
    match /categories/{catId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || !('userId' in resource.data) || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || !('userId' in resource.data) || isAdmin());
      
      allow create: if isSignedIn() && 
                      (incoming().userId == request.auth.uid || isAdmin()) &&
                      incoming().name is string && incoming().name.size() <= 50 &&
                      incoming().color is string && incoming().color.size() <= 20;

      allow update: if isSignedIn() && 
                      (existing().userId == request.auth.uid || isAdmin()) &&
                      (incoming().userId == existing().userId) &&
                      incoming().name is string && incoming().name.size() <= 50 &&
                      incoming().color is string && incoming().color.size() <= 20;
      
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }
  }
}
