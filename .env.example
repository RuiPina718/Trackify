# Gemini API Key for Chatbot (Required for AI features in Vercel)
GEMINI_API_KEY=

# Google OAuth for Calendar (Required for Calendar sync in Vercel)
# Construct these in Google Cloud Console with your Vercel URL as redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Note for Vercel Deployment:
# 1. Go to Vercel Project Settings > Environment Variables
# 2. Add GEMINI_API_KEY, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET
# 3. Add VITE_GOOGLE_CLIENT_ID (same as GOOGLE_CLIENT_ID) for client components if needed
# 4. Redeploy your application
