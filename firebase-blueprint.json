{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and preferences.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "currency": { "type": "string", "enum": ["USD", "EUR", "GBP", "BRL"] },
        "notifications": {
          "type": "object",
          "properties": {
            "billingReminders": { "type": "boolean" },
            "reminderDays": { "type": "number" },
            "usageAlerts": { "type": "boolean" },
            "spendingLimit": { "type": "number" }
          }
        }
      },
      "required": ["email", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "A recurring service subscription.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "billingCycle": { "type": "string", "enum": ["monthly", "annual", "weekly", "yearly"] },
        "billingDay": { "type": "number" },
        "billingMonth": { "type": "number" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "cancelled"] },
        "startDate": { "type": "string", "format": "date" },
        "nextBillingDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "amount", "billingCycle", "billingDay", "category", "status", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Subscription category (predefined or custom).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["name"]
    },
    "CalendarIntegration": {
      "title": "Calendar Integration",
      "description": "Google Calendar OAuth integration data.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "refreshToken": { "type": "string" },
        "status": { "type": "string", "enum": ["connected", "disconnected", "error"] },
        "lastSyncAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "refreshToken", "status", "createdAt"]
    },
    "CalendarEvent": {
      "title": "Calendar Event",
      "description": "Mapping between a subscription and a Google Calendar event.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subscriptionId": { "type": "string" },
        "googleEventId": { "type": "string" },
        "lastSyncedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "subscriptionId", "googleEventId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profiles"
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "Individual subscriptions"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Custom categories per user"
    },
    "/calendar_integrations/{userId}": {
      "schema": "CalendarIntegration",
      "description": "User Google Calendar integration settings"
    },
    "/calendar_events/{eventId}": {
      "schema": "CalendarEvent",
      "description": "Subscription to Google Event mappings"
    }
  }
}
